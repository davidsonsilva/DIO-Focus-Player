{
  "manifest_version": 3,
  "name": "DIO Focus Player — não oficial",
  "version": "1.0.0",
  "description": "Prioriza o player das aulas da DIO em janelas estreitas e telas divididas.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_title": "DIO Focus Player",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.dio.me/*"],
      "js": ["content.js"],
      "css": ["focus-mode.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}
